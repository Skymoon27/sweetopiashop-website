<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>My Sweet Life Digital Planner 🌸</title>
    <!-- Playful cute Google fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fredoka:wght=300..700&family=Quicksand:wght=300..700&display=swap" rel="stylesheet">
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Lucide Icons for adorable visual glyphs -->
    <script src="https://unpkg.com/lucide@latest"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        fredoka: ['"Fredoka"', 'sans-serif'],
                        quicksand: ['"Quicksand"', 'sans-serif'],
                    },
                    colors: {
                        sky: {
                            50: '#F0F9FF',
                            100: '#E0F2FE',
                            200: '#BAE6FD',
                            300: '#7DD3FC',
                            400: '#38BDF8',
                            500: '#0EA5E9',
                            950: '#0369A1'
                        },
                        pastelYellow: {
                            50: '#FFFDF0',
                            100: '#FEF9C3',
                            200: '#FEF08A',
                            300: '#FDE047',
                            400: '#FACC15'
                        },
                        pastelPink: {
                            50: '#FFF5F5',
                            100: '#FFE4E6',
                            200: '#FECDD3',
                            300: '#FDA4AF',
                            400: '#FB7185',
                            600: '#E11D48'
                        }
                    }
                }
            }
        }
    </script>
    
    <style>
        body {
            font-family: 'Quicksand', sans-serif;
            background-color: #FDFBF7;
            background-image: radial-gradient(#E0F2FE 1.2px, #FDFBF7 1.2px);
            background-size: 24px 24px;
        }

        h1, h2, h3, h4, .font-cute {
            font-family: 'Fredoka', sans-serif;
        }

        /* Print Preview Mode Styles */
        body.in-print-preview {
            background: #e2e8f0 !important;
            background-image: none !important;
            padding: 80px 10px 20px 10px !important;
            display: flex !important;
            flex-direction: column !important;
            align-items: center !important;
            justify-content: flex-start !important;
            overflow-y: auto !important;
        }

        body.in-print-preview #print-preview-header {
            display: flex !important;
        }

        body.in-print-preview #planner-header,
        body.in-print-preview #stylus-toolbar,
        body.in-print-preview #planner-sidebar-tabs,
        body.in-print-preview #planner-footer {
            display: none !important;
        }

        body.in-print-preview #planner-binder-frame {
            display: flex !important;
            max-width: 210mm !important;
            width: 100% !important;
            height: 297mm !important;
            margin: 0 auto !important;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15) !important;
            border-radius: 1.5rem !important;
            background: #ffffff !important;
            transform: none !important;
        }

        body.in-print-preview .outer-book-cover {
            background: #ffffff !important;
            padding: 0 !important;
            border: none !important;
            border-radius: 1.5rem !important;
            box-shadow: none !important;
            width: 100% !important;
            height: 100% !important;
        }

        body.in-print-preview .inner-double-page {
            border: 2px solid #BAE6FD !important;
            box-shadow: none !important;
            border-radius: 1.5rem !important;
            padding: 20mm !important;
            width: 100% !important;
            height: 100% !important;
            margin-left: 0 !important;
        }

        /* Hide spiral wire rings inside print preview */
        body.in-print-preview .outer-book-cover > .absolute {
            display: none !important;
        }

        @media (max-width: 768px) {
            body.in-print-preview #planner-binder-frame {
                height: auto !important;
                aspect-ratio: 1 / 1.414 !important;
            }
        }

        /* Paper texture lines */
        .paper-grid {
            background-image: linear-gradient(rgba(186, 230, 253, 0.15) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(186, 230, 253, 0.15) 1px, transparent 1px);
            background-size: 20px 20px;
        }

        /* Pink grid background */
        .pink-grid {
            background-color: #FFF0F0;
            background-image: linear-gradient(rgba(244, 63, 94, 0.08) 1px, transparent 1px),
                              linear-gradient(90deg, rgba(244, 63, 94, 0.08) 1px, transparent 1px);
            background-size: 22px 22px;
        }

        /* Gingham check pattern */
        .pink-gingham {
            background-color: #FFF5F5;
            background-image: linear-gradient(90deg, rgba(251, 113, 133, 0.12) 50%, transparent 50%),
                              linear-gradient(rgba(251, 113, 133, 0.12) 50%, transparent 50%);
            background-size: 24px 24px;
        }

        /* Stunning purple/pink template background */
        .monthly-dotted-canvas {
            background-color: #FFFFFF;
            background-image: radial-gradient(#BE9FE1 1.2px, transparent 1.2px);
            background-size: 14px 14px;
            border: 2px solid #E4D5F6;
        }

        .notes-dotted-lines {
            background-image: linear-gradient(to bottom, transparent 95%, rgba(244, 63, 94, 0.12) 95%);
            background-size: 100% 24px;
            background-repeat: repeat;
            line-height: 24px;
        }

        .paper-lines {
            background-image: linear-gradient(#f0f0f0 1px, transparent 1px);
            background-size: 100% 24px;
        }

        /* Custom Input Dates styling for uniform cute look */
        input[type="date"], input[type="month"] {
            border: 1px solid #BAE6FD;
            border-radius: 0.75rem;
            padding: 0.25rem 0.5rem;
            background-color: #ffffff;
            color: #0369A1;
            font-size: 0.75rem;
            font-family: 'Fredoka', sans-serif;
            outline: none;
            transition: all 0.2s;
        }
        input[type="date"]:focus, input[type="month"]:focus {
            border-color: #7DD3FC;
            box-shadow: 0 0 0 2px rgba(125, 211, 252, 0.2);
        }

        /* Customized scrollbars inside book pages */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(254, 249, 195, 0.2);
            border-radius: 99px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: #BAE6FD;
            border-radius: 99px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: #7DD3FC;
        }

        /* Hide mobile scrollbars */
        .scrollbar-none::-webkit-scrollbar {
            display: none;
        }
        .scrollbar-none {
            -ms-overflow-style: none;  /* IE/Edge */
            scrollbar-width: none;  /* Firefox */
        }

        /* Interactive wiggles */
        .cute-hover {
            transition: transform 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        }
        .cute-hover:hover {
            transform: scale(1.03) rotate(-0.5deg);
        }

        /* Active tab styling transitions */
        .tab-active {
            z-index: 40 !important;
            box-shadow: 0 4px 10px rgba(0,0,0,0.06);
            border-bottom-color: transparent !important;
        }
        
        @media (min-width: 768px) {
            .tab-active {
                transform: translateX(6px) scale(1.05);
                border-left-color: transparent !important;
                border-bottom-color: #f3f4f6 !important;
            }
        }

        /* Stylus Mode Canvas Overlay styles */
        .drawing-canvas {
            touch-action: none;
        }

        /* Sticker Physics Drop Animation */
        @keyframes dropSticker {
            0% { transform: translateY(-160px) scale(1.4) rotate(0deg); opacity: 0; }
            60% { transform: translateY(10px) scale(0.9) rotate(var(--rot-deg, 5deg)); }
            80% { transform: translateY(-5px) scale(1.05) rotate(var(--rot-deg, 5deg)); }
            100% { transform: translateY(0) scale(1) rotate(var(--rot-deg, 5deg)); opacity: 1; }
        }
        .animate-drop-cozy {
            animation: dropSticker 0.45s cubic-bezier(0.175, 0.885, 0.32, 1.25) forwards;
        }

        @keyframes bounceShort {
            0%, 100% { transform: translateY(0) rotate(var(--rot-deg, 0deg)); }
            50% { transform: translateY(-3px) rotate(var(--rot-deg, 0deg)); }
        }
        .animate-bounce-short {
            animation: bounceShort 2.5s infinite ease-in-out;
        }

        .quilted-pattern {
            background-color: #FFDEE9;
            background-image: linear-gradient(135deg, #FFDEE9 0%, #B5FFFC 100%);
            position: relative;
        }
        .quilted-pattern::after {
            content: '';
            position: absolute;
            inset: 0;
            background-image: 
                radial-gradient(circle, rgba(255,255,255,0.4) 1px, transparent 1px),
                linear-gradient(45deg, rgba(255,182,193,0.15) 25%, transparent 25%, transparent 75%, rgba(255,182,193,0.15) 75%),
                linear-gradient(135deg, rgba(255,182,193,0.15) 25%, transparent 25%, transparent 75%, rgba(255,182,193,0.15) 75%);
            background-size: 20px 20px, 40px 40px, 40px 40px;
            background-position: 0 0, 0 0, 20px 20px;
            opacity: 0.85;
            pointer-events: none;
            border-radius: inherit;
        }

        /* Biometric Ripple Pulse Effect */
        @keyframes fingerprintPulse {
            0% { transform: scale(0.9); opacity: 0.9; }
            50% { transform: scale(1.15); opacity: 0.4; }
            100% { transform: scale(1.4); opacity: 0; }
        }
        .scanner-pulse {
            animation: fingerprintPulse 1.6s infinite ease-out;
        }

        @media print {
            @page {
                size: A4 portrait;
                margin: 0.8cm;
            }
            body {
                background: none !important;
                background-color: #ffffff !important;
                padding: 0 !important;
                margin: 0 !important;
                overflow: visible !important;
            }
            header, footer, nav, #mood-selector, .no-print, button, select, 
            input[type="button"], #audio-btn, #stylus-toolbar, #stylus-toggle-btn, #print-preview-header {
                display: none !important;
            }
            main {
                margin: 0 !important;
                padding: 0 !important;
                width: 100% !important;
                max-width: 100% !important;
                height: auto !important;
                box-shadow: none !important;
                transform: none !important;
                position: relative !important;
            }
            .outer-book-cover {
                background: none !important;
                border: none !important;
                box-shadow: none !important;
                padding: 0 !important;
                margin: 0 !important;
                width: 100% !important;
                height: auto !important;
            }
            .outer-book-cover > .absolute {
                display: none !important;
            }
            .inner-double-page {
                border: 2px solid #BAE6FD !important;
                box-shadow: none !important;
                background-color: #ffffff !important;
                width: 100% !important;
                height: auto !important;
                border-radius: 1.5rem !important;
                padding: 16px !important;
                margin-left: 0 !important;
            }
            .planner-page {
                display: block !important;
                opacity: 1 !important;
                height: auto !important;
                max-height: none !important;
                overflow: visible !important;
            }
            input, textarea, select {
                border: none !important;
                background: transparent !important;
                resize: none !important;
                box-shadow: none !important;
                appearance: none !important;
                color: #0369A1 !important;
            }
            .custom-scrollbar {
                max-height: none !important;
                overflow: visible !important;
            }
            * {
                -webkit-print-color-adjust: exact !important;
                print-color-adjust: exact !important;
            }
        }
    </style>
</head>
<body class="min-h-screen flex flex-col items-center justify-start p-2.5 sm:p-6 overflow-x-hidden select-none">

    <div id="print-preview-header" class="hidden fixed top-0 left-0 right-0 h-16 bg-white border-b border-sky-100 shadow-md flex items-center justify-between px-4 sm:px-8 z-50 no-print">
        <div class="flex items-center gap-2">
            <div class="bg-emerald-50 p-2 rounded-full border border-emerald-150 text-emerald-600">
                <i data-lucide="printer" class="w-4 h-4"></i>
            </div>
            <div>
                <h4 class="text-xs sm:text-sm font-bold text-sky-955 font-cute">A4 Print Preview Mode</h4>
                <p class="text-[9px] sm:text-[10px] text-sky-955/65 font-medium">Verify your handwritings & lists before printing as normal PDF.</p>
            </div>
        </div>
        <div class="flex items-center gap-2">
            <button onclick="triggerNormalPrint()" class="flex items-center gap-1.5 bg-emerald-400 hover:bg-emerald-500 text-white font-cute font-bold text-xs py-2 px-4 rounded-xl transition shadow-sm">
                <span>Print PDF Now</span>
            </button>
            <button onclick="togglePrintPreview(false)" class="flex items-center gap-1 bg-rose-400 hover:bg-rose-500 text-white font-cute font-bold text-xs py-2 px-4 rounded-xl transition shadow-sm">
                <span>Exit Preview</span>
            </button>
        </div>
    </div>

    <header id="planner-header" class="hidden w-full max-w-4xl flex flex-col md:flex-row items-center justify-between mb-4 gap-3 z-10 no-print">
        <div class="flex items-center gap-3">
            <div class="bg-pastelYellow-200 p-2 rounded-full shadow-sm border border-pastelYellow-300 animate-bounce">
                <span class="text-xl sm:text-2xl">🧸</span>
            </div>
            <div>
                <h1 id="lbl-app-title" class="text-xl sm:text-2xl md:text-3xl font-bold text-sky-955 flex items-center gap-1.5 flex-wrap" data-t="app_title">
                    My Sweet Life Digital Planner <span class="text-pastelPink-300 text-sm sm:text-base">🎀</span>
                </h1>
                <p id="lbl-app-subtitle" class="text-[10px] sm:text-xs text-sky-955/70 font-medium" data-t="app_subtitle">Your cozy responsive personal binder. Handcrafted with love 🌸</p>
            </div>
        </div>

        <!-- Custom Controls Drawer -->
        <div class="flex flex-wrap items-center gap-2 sm:gap-3 bg-white/80 backdrop-blur px-3 sm:px-4 py-1.5 sm:py-2 rounded-2xl border border-sky-100 shadow-sm w-full md:w-auto justify-between md:justify-start">
            <div class="flex items-center gap-1.5">
                <span id="lbl-mood-head" class="text-[10px] sm:text-xs font-bold text-sky-955" data-t="mood">Mood:</span>
                <div class="flex gap-1" id="mood-selector">
                    <button onclick="setMood('😊')" class="hover:scale-125 transition duration-150 text-xs sm:text-sm" title="Happy">😊</button>
                    <button onclick="setMood('🧸')" class="hover:scale-125 transition duration-150 text-xs sm:text-sm" title="Cozy">🧸</button>
                    <button onclick="setMood('✨')" class="hover:scale-125 transition duration-150 text-xs sm:text-sm" title="Productive">✨</button>
                    <button onclick="setMood('🌸')" class="hover:scale-125 transition duration-150 text-xs sm:text-sm" title="Sweet">🌸</button>
                    <button onclick="setMood('😴')" class="hover:scale-125 transition duration-150 text-xs sm:text-sm" title="Sleepy">😴</button>
                </div>
                <span id="active-mood" class="bg-pastelYellow-100 px-1.5 py-0.5 rounded-lg text-[10px] sm:text-xs font-bold text-sky-955 border border-pastelYellow-200 ml-1">😊</span>
            </div>
            
            <div class="flex items-center gap-2">
                <div class="border-l border-sky-100 h-5"></div>
                
                <!-- Bilingual Translation Button -->
                <button onclick="toggleLanguage()" class="flex items-center gap-1 bg-sky-100 hover:bg-sky-200 text-sky-955 font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg border border-sky-200 transition" title="Tukar Bahasa / Switch Language">
                    <span class="text-xs">🌐</span>
                    <span id="lang-text" class="font-cute">EN</span>
                </button>

                <!-- Stylus Pen Mode Toggle -->
                <button onclick="toggleStylusMode()" id="stylus-toggle-btn" class="flex items-center gap-1 bg-pastelYellow-100 hover:bg-pastelYellow-200 text-sky-955 font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg border border-pastelYellow-300 transition" title="Toggle Stylus Writing Pen Mode">
                    <span id="stylus-status-icon">✏️</span>
                    <span id="stylus-status-text">Stylus Off</span>
                </button>
                
                <!-- PDF Portrait Printer Button -->
                <button onclick="printPlanner()" class="flex items-center gap-1 bg-sky-400 hover:bg-sky-500 text-white font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg transition" title="Export PDF Page View">
                    <i data-lucide="printer" class="w-3.5 h-3.5"></i>
                    <span id="lbl-pdf-print" data-t="pdf_print">PDF Print</span>
                </button>

                <!-- Lock Binder Button -->
                <button onclick="lockPlannerBinder()" class="flex items-center gap-1 bg-amber-400 hover:bg-amber-500 text-white font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg transition" title="Lock Binder Cover">
                    <i data-lucide="lock" class="w-3.5 h-3.5"></i>
                    <span id="lbl-lock-action" data-t="lock_binder">Lock Binder</span>
                </button>

                <!-- Audio Switcher -->
                <button onclick="toggleAudio()" id="audio-btn" class="text-sky-955/60 hover:text-sky-955 transition p-1" title="Toggle Page Flip Sound">
                    <i data-lucide="volume-2" class="w-4 h-4"></i>
                </button>
            </div>
        </div>
    </header>

    <div id="stylus-toolbar" class="hidden w-full max-w-4xl mb-3 flex flex-wrap items-center justify-between gap-3 bg-white/95 border border-pastelYellow-200 p-2.5 rounded-2xl shadow-sm z-30 no-print animate-fade-in">
        <div class="flex items-center gap-2 flex-wrap">
            <span id="lbl-pen-crayon" class="text-[10px] sm:text-xs font-bold text-sky-955 flex items-center gap-1" data-t="pen_crayon">🎨 Pen Crayon:</span>
            <!-- Color options -->
            <div class="flex gap-1.5 items-center bg-sky-50/50 p-1 rounded-lg border border-sky-100">
                <button id="color-strawberry" onclick="setPenColor('#FDA4AF')" class="w-5 h-5 rounded-full border-2 border-white ring-2 ring-pastelPink-300 shadow-sm" style="background-color: #FDA4AF;" title="Strawberry Pink"></button>
                <button id="color-cloud" onclick="setPenColor('#38BDF8')" class="w-5 h-5 rounded-full border-2 border-white" style="background-color: #38BDF8;" title="Cloud Blue"></button>
                <button id="color-honey" onclick="setPenColor('#FACC15')" class="w-5 h-5 rounded-full border-2 border-white" style="background-color: #FACC15;" title="Honey Yellow"></button>
                <button id="color-charcoal" onclick="setPenColor('#374151')" class="w-5 h-5 rounded-full border-2 border-white" style="background-color: #374151;" title="Charcoal Grey"></button>
            </div>
            
            <!-- Customizable Size Slider -->
            <div class="flex items-center gap-1.5 bg-sky-50/50 p-1 rounded-lg border border-sky-100 text-[10px]">
                <span id="lbl-pen-size" class="font-bold text-sky-955" data-t="size">Size:</span>
                <input type="range" id="pen-size-slider" min="1" max="100" value="5" oninput="updatePenSize(this.value)" class="w-20 sm:w-28 h-1 bg-sky-200 rounded-lg appearance-none cursor-pointer accent-sky-500">
                <span id="pen-size-display" class="font-bold text-sky-955 w-7 text-center">5%</span>
            </div>
        </div>
        
        <div class="flex items-center gap-2">
            <!-- Undo / Redo tools -->
            <div class="flex gap-1 bg-sky-50/50 p-1 rounded-lg border border-sky-100 text-[10px] sm:text-xs">
                <button onclick="undoStylus()" class="px-2 py-0.5 font-bold rounded hover:bg-sky-100 text-sky-955 flex items-center gap-0.5" title="Undo"><span id="lbl-undo" data-t="undo">↩️ Undo</span></button>
                <button onclick="redoStylus()" class="px-2 py-0.5 font-bold rounded hover:bg-sky-100 text-sky-955 flex items-center gap-0.5" title="Redo"><span id="lbl-redo" data-t="redo">↪️ Redo</span></button>
            </div>

            <!-- Draw vs Eraser toggles -->
            <div class="flex gap-1 bg-sky-50/50 p-1 rounded-lg border border-sky-100 text-[10px] sm:text-xs">
                <button id="tool-pen-btn" onclick="setPenTool('pen')" class="px-2.5 py-0.5 font-bold rounded bg-sky-400 text-white flex items-center gap-1" data-t="draw">✏️ Draw</button>
                <button id="tool-eraser-btn" onclick="setPenTool('eraser')" class="px-2.5 py-0.5 font-bold rounded hover:bg-sky-100 text-sky-955/70 flex items-center gap-1" data-t="eraser">🧽 Eraser</button>
            </div>
            <!-- Clear Action -->
            <button id="lbl-clear-btn" onclick="openClearDrawingsModal()" class="text-rose-400 hover:text-rose-600 hover:bg-rose-50 font-bold text-[10px] sm:text-xs px-2.5 py-1.5 rounded-xl border border-rose-100 transition" data-t="clear_handwritings">✨ Clear Page Markings</button>
        </div>
    </div>

    <div id="book-cover-screen" class="w-full max-w-lg mx-auto flex flex-col items-center justify-center min-h-[80vh] relative z-40 p-4">
        <!-- Physical Book Binder Outer Structure -->
        <div class="quilted-pattern w-full rounded-[2.5rem] border-[6px] border-white shadow-[0_25px_60px_-15px_rgba(225,29,72,0.25)] p-6 sm:p-8 relative flex flex-col justify-between items-center text-center select-text min-h-[580px] hover:shadow-[0_30px_70px_rgba(225,29,72,0.35)] transition-all duration-500">
            
            <!-- Cozy Stitching Edges -->
            <div class="absolute inset-2 rounded-[2rem] border-2 border-dashed border-white/60 pointer-events-none"></div>

            <!-- Skeuomorphic Leather Binder Strap & Latch Lock -->
            <div class="absolute -right-3 top-1/2 transform -translate-y-1/2 w-16 h-12 bg-rose-200 border-2 border-white rounded-l-xl shadow-md flex items-center justify-center z-20 pointer-events-none">
                <div class="w-8 h-8 bg-amber-400 rounded-full border-2 border-white flex items-center justify-center shadow-sm">
                    <span class="text-sm">💖</span>
                </div>
            </div>

            <div class="w-full pt-4 z-10">
                <div class="mx-auto w-16 h-16 bg-white/90 rounded-full flex items-center justify-center border-4 border-rose-200 shadow-inner mb-3">
                    <span class="text-3xl animate-pulse">🌸</span>
                </div>
                <!-- Binder Book Title Requested: My Sweet Planner -->
                <h1 id="lbl-cover-title" class="text-3xl sm:text-4xl font-extrabold text-rose-950 font-cute tracking-wider drop-shadow-md">My Sweet Planner</h1>
                <p id="lbl-cover-subtitle" class="text-xs text-rose-800/80 font-semibold mt-1 italic" data-t="cover_sub">Your secure cozy digital diary 🔒</p>
            </div>

            <!-- Library Owner Login Identification Card -->
            <div class="w-full bg-white/95 rounded-3xl p-5 border-2 border-rose-100 shadow-md mt-6 mb-6 z-10 max-w-sm relative">
                <!-- Swappable Authentication Forms -->
                
                <!-- 1. SIGN IN FORM -->
                <div id="cover-signin-form" class="space-y-3.5">
                    <h3 class="text-sm font-bold text-rose-900 tracking-wide flex items-center justify-center gap-1">
                        <span>🎀</span> <span id="lbl-signin-header" data-t="sign_in">Sign In to Owner File</span>
                    </h3>
