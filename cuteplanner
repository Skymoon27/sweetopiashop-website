        }

        function renderEvent() {
            const dict = translations[plannerData.lang || 'en'];
            const eventObj = plannerData.event;
            if (!eventObj) return;

            document.getElementById('event-active-label').innerText = eventObj.title;
            document.getElementById('event-name-input').value = eventObj.title;
            document.getElementById('event-date-input').value = eventObj.date;

