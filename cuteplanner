        function renderCalendar() {
            const grid = document.getElementById('calendar-days-grid');
            if (!grid) return;
            grid.innerHTML = '';
            
            const currentMonthStr = plannerData.currentMonth || "2026-06";
            document.getElementById('calendar-month-select').value = currentMonthStr;

            if (!plannerData.monthlyNotes) plannerData.monthlyNotes = {};
            document.getElementById('monthly-notes-textarea').value = plannerData.monthlyNotes[currentMonthStr] || '';

            const year = parseInt(currentMonthStr.split("-")[0]);
            const monthIdx = parseInt(currentMonthStr.split("-")[1]) - 1;

            const firstDayDate = new Date(year, monthIdx, 1);
            const totalDaysInMonth = new Date(year, monthIdx + 1, 0).getDate();
            const paddingDays = firstDayDate.getDay();

            for (let i = 0; i < paddingDays; i++) {
                const emptyCell = document.createElement('div');
                emptyCell.className = "aspect-square rounded-lg bg-transparent";
                grid.appendChild(emptyCell);
            }

            for (let day = 1; day <= totalDaysInMonth; day++) {
                const monthStr = (monthIdx + 1) < 10 ? '0' + (monthIdx + 1) : (monthIdx + 1);
                const dayStr = day < 10 ? '0' + day : day;
                const dateKey = `${year}-${monthStr}-${dayStr}`;
                const hasDiaryEntry = plannerData.diary[dateKey] && plannerData.diary[dateKey].trim() !== "";
                
                const dayBtn = document.createElement('button');
                dayBtn.className = `aspect-square flex flex-col items-center justify-between p-1 rounded-xl border text-[10px] sm:text-xs font-cute transition-all relative ${
