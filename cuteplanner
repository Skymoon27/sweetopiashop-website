                        <span class="${c.done ? 'line-through' : ''} text-[#5C2C16] truncate">${c.text}</span>
                    </div>
                    <button onclick="deleteEventChecklist(${c.id})" class="text-gray-300 hover:text-rose-400 no-print">
                        <i data-lucide="x" class="w-3 h-3"></i>
                    </button>
                `;
                checkContainer.appendChild(div);
            });
            document.getElementById('event-checklist-count').innerText = `Done: ${checkedCount} / ${eventObj.checklist.length}`;

            lucide.createIcons();
