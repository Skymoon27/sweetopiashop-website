        }

        function deleteEventChecklist(id) {
            plannerData.event.checklist = plannerData.event.checklist.filter(item => item.id !== id);
            saveToLocalStorage();
            renderEvent();
        }

        let stylusActive = false;
        let activeTool = 'pen';
        let penColor = '#FDA4AF';
        let penWidth = 5;
        let historyData = {};

        const canvasMain = document.getElementById('canvas-main');
        let drawingState = { isDrawing: false, lastX: 0, lastY: 0 };

        function toggleStylusMode() {
            stylusActive = !stylusActive;
            const toggleBtn = document.getElementById('stylus-toggle-btn');
            const toolbar = document.getElementById('stylus-toolbar');
            const dict = translations[plannerData.lang || 'en'];
            
            if (stylusActive) {
                toggleBtn.innerHTML = `<span id="stylus-status-icon">🖋️</span> <span id="stylus-status-text">${dict.stylus_on}</span>`;
                toggleBtn.className = "flex items-center gap-1 bg-sky-400 hover:bg-sky-500 text-white font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg border border-sky-500 transition shadow-md";
                toolbar.classList.remove('hidden');
                canvasMain.classList.remove('pointer-events-none');
            } else {
                toggleBtn.innerHTML = `<span id="stylus-status-icon">✏️</span> <span id="stylus-status-text">${dict.stylus_off}</span>`;
                toggleBtn.className = "flex items-center gap-1 bg-pastelYellow-100 hover:bg-pastelYellow-200 text-[#5C2C16] font-bold text-[10px] sm:text-xs py-1 px-2.5 rounded-lg border border-pastelYellow-300 transition";
                toolbar.classList.add('hidden');
                canvasMain.classList.add('pointer-events-none');
            }
        }

        function setPenColor(color) {
            penColor = color;
            const btns = ['strawberry', 'cloud', 'honey', 'charcoal'];
            btns.forEach(b => {
                const button = document.getElementById('color-' + b);
                if (button) button.classList.remove('ring-2', 'ring-pastelPink-300');
            });
            let chosenBtnId = 'strawberry';
            if (color === '#38BDF8') chosenBtnId = 'cloud';
            else if (color === '#FACC15') chosenBtnId = 'honey';
            else if (color === '#374151') chosenBtnId = 'charcoal';
            
            document.getElementById('color-' + chosenBtnId).classList.add('ring-2', 'ring-pastelPink-300');
        }

        function updatePenSize(val) {
            penWidth = parseInt(val);
            const slider = document.getElementById('pen-size-slider');
            const display = document.getElementById('pen-size-display');
            if (slider) slider.value = val;
            if (display) display.innerText = val + '%';
        }

        function saveInitialState(canvas, tabId) {
            if (!historyData[tabId]) {
                historyData[tabId] = { undo: [], redo: [] };
            }
            historyData[tabId].undo = [canvas.toDataURL()];
            historyData[tabId].redo = [];
        }

        function pushToHistory(tabId, dataUrl) {
            if (!historyData[tabId]) {
                historyData[tabId] = { undo: [], redo: [] };
            }
            historyData[tabId].undo.push(dataUrl);
            if (historyData[tabId].undo.length > 30) {
                historyData[tabId].undo.shift();
            }
            historyData[tabId].redo = [];
        }

        function undoStylus() {
            const tabId = plannerData.currentTab;
            const hist = historyData[tabId];
            if (!hist || hist.undo.length <= 1) return;

            const current = hist.undo.pop();
            hist.redo.push(current);

            const previousState = hist.undo[hist.undo.length - 1];
            restoreCanvasFromDataUrl(previousState);
        }

        function redoStylus() {
            const tabId = plannerData.currentTab;
            const hist = historyData[tabId];
            if (!hist || hist.redo.length === 0) return;

            const next = hist.redo.pop();
            hist.undo.push(next);
            restoreCanvasFromDataUrl(next);
        }

        function restoreCanvasFromDataUrl(dataUrl) {
            const ctx = canvasMain.getContext('2d');
            ctx.clearRect(0, 0, canvasMain.width, canvasMain.height);
            const img = new Image();
            img.onload = function() {
                ctx.drawImage(img, 0, 0, canvasMain.width, canvasMain.height);
                saveCanvasState(canvasMain, 'drawing_tab_' + plannerData.currentTab);
            };
            img.src = dataUrl;
        }

        function setPenTool(tool) {
            activeTool = tool;
            const penBtn = document.getElementById('tool-pen-btn');
            const eraserBtn = document.getElementById('tool-eraser-btn');
            
            if (tool === 'pen') {
                penBtn.className = "px-2.5 py-0.5 font-bold rounded bg-sky-400 text-white flex items-center gap-1";
                eraserBtn.className = "px-2.5 py-0.5 font-bold rounded hover:bg-sky-100 text-sky-955/70 flex items-center gap-1";
            } else {
                penBtn.className = "px-2.5 py-0.5 font-bold rounded hover:bg-sky-100 text-sky-955/70 flex items-center gap-1";
                eraserBtn.className = "px-2.5 py-0.5 font-bold rounded bg-sky-400 text-white flex items-center gap-1";
            }
        }

        function drawRoundRect(ctx, x, y, width, height, radius) {
            ctx.beginPath();
            ctx.moveTo(x + radius, y);
            ctx.lineTo(x + width - radius, y);
            ctx.quadraticCurveTo(x + width, y, x + width, y + radius);
            ctx.lineTo(x + width, y + height - radius);
            ctx.quadraticCurveTo(x + width, y + height, x + width - radius, y + height);
            ctx.lineTo(x + radius, y + height);
            ctx.quadraticCurveTo(x, y + height, x, y + height - radius);
            ctx.lineTo(x, y + radius);
            ctx.quadraticCurveTo(x, y, x + radius, y);
            ctx.closePath();
        }

        function drawMobileSwipeHintOnCanvas(canvas) {
            if (window.innerWidth >= 768) return;

            const ctx = canvas.getContext('2d');
            ctx.save();
            ctx.font = 'bold 9px "Fredoka", sans-serif';
            ctx.textBaseline = 'middle';
            ctx.textAlign = 'center';
            
            const text = translations[plannerData.lang || 'en'].canvas_swipe_hint;
            const textWidth = ctx.measureText(text).width;
            
            const x = canvas.width / 2;
            const y = 22;

            const paddingX = 8;
            const paddingY = 4;
            const rx = x - (textWidth / 2) - paddingX;
            const ry = y - 9;
            const rw = textWidth + (paddingX * 2);
            const rh = 14 + paddingY;

            ctx.fillStyle = 'rgba(255, 241, 242, 0.95)';
            drawRoundRect(ctx, rx, ry, rw, rh, 6);
            ctx.fill();

            ctx.strokeStyle = '#FDA4AF';
            ctx.lineWidth = 1;
            ctx.setLineDash([3, 3]);
            ctx.stroke();

            ctx.fillStyle = '#BE123C';
            ctx.fillText(text, x, y + 1);
            ctx.restore();
        }

        function initCanvasSize(canvas, storageKey) {
            const rect = canvas.parentElement.getBoundingClientRect();
            if (rect.width === 0 || rect.height === 0) return;

            canvas.width = rect.width;
            canvas.height = rect.height;

            const ctx = canvas.getContext('2d');
            ctx.lineCap = 'round';
            ctx.lineJoin = 'round';

            const savedData = localStorage.getItem(storageKey);
            if (savedData) {
                const img = new Image();
                img.onload = function() {
                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);
                    saveInitialState(canvas, plannerData.currentTab);
                    drawMobileSwipeHintOnCanvas(canvas);
                }
                img.src = savedData;
            } else {
                saveInitialState(canvas, plannerData.currentTab);
                drawMobileSwipeHintOnCanvas(canvas);
            }
        }

        function saveCanvasState(canvas, storageKey) {
            if (!storageKey) return;
            const dataUrl = canvas.toDataURL();
            localStorage.setItem(storageKey, dataUrl);
        }

        function getCanvasCoords(e, canvas) {
            const rect = canvas.getBoundingClientRect();
            if (e.touches && e.touches.length > 0) {
                return {
                    x: e.touches[0].clientX - rect.left,
                    y: e.touches[0].clientY - rect.top
                };
            }
            return {
                x: e.clientX - rect.left,
                y: e.clientY - rect.top
            };
        }

        function bindDrawingListeners(canvas) {
            const ctx = canvas.getContext('2d');

            function startDrawing(e) {
                if (!stylusActive) return;
                e.preventDefault();
                
                const coords = getCanvasCoords(e, canvas);
                drawingState.isDrawing = true;
                drawingState.lastX = coords.x;
                drawingState.lastY = coords.y;

                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
                
                ctx.arc(coords.x, coords.y, penWidth / 2, 0, Math.PI * 2);
                ctx.fillStyle = activeTool === 'eraser' ? '#FDFBF7' : penColor; 
                ctx.globalCompositeOperation = 'source-over';
                
                ctx.fill();
                ctx.beginPath();
                ctx.moveTo(coords.x, coords.y);
            }

            function draw(e) {
                if (!stylusActive || !drawingState.isDrawing) return;
                e.preventDefault();
                const coords = getCanvasCoords(e, canvas);

                ctx.lineWidth = penWidth;
                ctx.strokeStyle = activeTool === 'eraser' ? '#FDFBF7' : penColor;
                ctx.globalCompositeOperation = 'source-over';

                ctx.beginPath();
                ctx.moveTo(drawingState.lastX, drawingState.lastY);
                ctx.lineTo(coords.x, coords.y);
                ctx.stroke();

                drawingState.lastX = coords.x;
                drawingState.lastY = coords.y;
            }

            function stopDrawing() {
                if (!drawingState.isDrawing) return;
                drawingState.isDrawing = false;
                
                const storageKey = 'drawing_tab_' + plannerData.currentTab;
                saveCanvasState(canvas, storageKey);
                pushToHistory(plannerData.currentTab, canvas.toDataURL());
            }

            canvas.addEventListener('mousedown', startDrawing);
            canvas.addEventListener('mousemove', draw);
            canvas.addEventListener('mouseup', stopDrawing);
            canvas.addEventListener('mouseleave', stopDrawing);

            canvas.addEventListener('touchstart', startDrawing);
            canvas.addEventListener('touchmove', draw);
            canvas.addEventListener('touchend', stopDrawing);
        }

        window.onload = function () {
            const todayStr = new Date().toISOString().split('T')[0];
            const currentMonthDefault = todayStr.substring(0, 7);

            if (!plannerData.currentMonth) plannerData.currentMonth = currentMonthDefault;
            if (!plannerData.diaryDate) plannerData.diaryDate = todayStr;
            
            const getMondayStr = (d) => {
                d = new Date(d);
                const day = d.getDay();
                const diff = d.getDate() - day + (day === 0 ? -6 : 1);
                return new Date(d.setDate(diff)).toISOString().split('T')[0];
            }
            const thisMondayStr = getMondayStr(new Date());
            
            if (!plannerData.weeklyWeek) plannerData.weeklyWeek = thisMondayStr;
            if (!plannerData.mealsWeek) plannerData.mealsWeek = thisMondayStr;

            const dateDisplayOpt = { month: 'long', year: 'numeric' };
            document.getElementById('current-date-span').innerText = new Date().toLocaleDateString('en-US', dateDisplayOpt);
            document.getElementById('diary-date-select').value = plannerData.diaryDate;
            document.getElementById('weekly-week-select').value = plannerData.weeklyWeek;
            document.getElementById('meals-week-select').value = plannerData.mealsWeek;

            document.getElementById('todo-custom-date').value = plannerData.todoDate || todayStr;
            document.getElementById('budget-date-input').value = todayStr;
            document.getElementById('movie-date-input').value = todayStr;

            document.getElementById('active-mood').innerText = plannerData.mood || '😊';
            document.getElementById('water-count').innerText = plannerData.water || 0;
            document.getElementById('sticky-notepad').value = plannerData.stickyNote || '';
            document.getElementById('diary-content').value = plannerData.diary[plannerData.diaryDate] || '';

            bindDrawingListeners(canvasMain);
            
            // Render view state based on isLocked parameter
            if (plannerData.isLocked) {
                lockPlannerBinder();
            } else {
                unlockPlannerBinder();
            }

            updateLanguageUI();
            updateAudioButtonUI();

            setTimeout(() => {
                initCanvasSize(canvasMain, 'drawing_tab_' + plannerData.currentTab);
            }, 100);
            
            lucide.createIcons();
        }

        window.addEventListener('beforeprint', () => {
            initCanvasSize(canvasMain, 'drawing_tab_' + plannerData.currentTab);
        });

        window.onresize = function() {
            initCanvasSize(canvasMain, 'drawing_tab_' + plannerData.currentTab);
        }

        document.pointerdown = function() {
            if (!audioCtx) {
                audioCtx = new (window.AudioContext || window.webkitAudioContext)();
            }
            if (audioCtx && audioCtx.state === 'suspended') {
                audioCtx.resume();
            }
        };

        function printPlanner() {
            window.print();
        }
    </script>
