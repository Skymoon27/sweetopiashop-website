                    </div>
                    <div class="flex items-center gap-1 bg-sky-50/60 p-1.5 rounded-lg justify-between text-xs">
                        <span class="text-[9px] text-sky-800 font-bold">${dict.watched_date}</span>
                        <input type="date" value="${movie.date || ''}" onchange="updateMovieDate(${movie.id}, this.value)" class="text-[9px] font-cute px-1 py-0.5 border-0 bg-transparent focus:ring-0 max-w-[120px] cursor-pointer">
                    </div>
