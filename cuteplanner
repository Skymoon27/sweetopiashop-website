                };
            }

            const weekMap = plannerData.meals[activeWeek];
            const weekDateObj = new Date(activeWeek);

            days.forEach((day, index) => {
                const plan = weekMap[day] || { breakfast: "—", lunch: "—", dinner: "—" };
                const optionDate = new Date(weekDateObj);
                optionDate.setDate(weekDateObj.getDate() + index);
                const dateLabel = optionDate.toLocaleDateString('en-US', { day: 'numeric', month: 'short' });

                const div = document.createElement('div');
                div.className = "bg-white p-2.5 rounded-xl border border-sky-100 shadow-sm text-xs space-y-1 flex flex-col justify-between";
                div.innerHTML = `
                    <div class="flex items-center justify-between border-b border-sky-50 pb-1 mb-1">
                        <span class="font-cute font-bold text-[#5C2C16]">${day}</span>
                        <span class="text-[9px] text-sky-400 font-bold">${dateLabel}</span>
                    </div>
                    <div class="text-[10px] text-sky-955/80 leading-tight">Breakfast: ${plan.breakfast}</div>
                    <div class="text-[10px] text-sky-955/80 leading-tight">Lunch: ${plan.lunch}</div>
                    <div class="text-[10px] text-sky-955/80 leading-tight">Dinner: ${plan.dinner}</div>
                `;
                container.appendChild(div);
            });
        }

        function changeMealsWeek(value) {
            plannerData.mealsWeek = value;
            saveToLocalStorage();
            renderMeals();
        }

        function saveMealPlan() {
            const activeWeek = plannerData.mealsWeek || "2026-06-22";
            const day = document.getElementById('meal-day-select').value;
            const breakfast = document.getElementById('meal-breakfast').value.trim() || "—";
            const lunch = document.getElementById('meal-lunch').value.trim() || "—";
            const dinner = document.getElementById('meal-dinner').value.trim() || "—";

            if (!plannerData.meals[activeWeek]) {
                plannerData.meals[activeWeek] = {};
            }
            plannerData.meals[activeWeek][day] = { breakfast, lunch, dinner };
            saveToLocalStorage();
            renderMeals();
            
            document.getElementById('meal-breakfast').value = '';
            document.getElementById('meal-lunch').value = '';
            document.getElementById('meal-dinner').value = '';
        }

        function renderMovies() {
            const container = document.getElementById('movies-container');
            if (!container) return;
            container.innerHTML = '';
            const dict = translations[plannerData.lang || 'en'];

            if (plannerData.movies.length === 0) {
                container.innerHTML = `<div class="p-8 text-center text-xs text-sky-955/30 col-span-2">${dict.empty_cinema}</div>`;
                return;
            }

            plannerData.movies.forEach(movie => {
                let starCount = parseInt(movie.rating) || 5;
                let starGlows = '⭐'.repeat(starCount);

                const card = document.createElement('div');
                card.className = "bg-white p-3 rounded-2xl border border-sky-100 flex flex-col justify-between shadow-sm relative gap-1.5";
                card.innerHTML = `
                    <div class="flex items-start justify-between">
                        <div>
                            <span class="text-[9px] text-sky-400 font-bold">🎬 Review Log</span>
                            <h3 class="text-xs font-bold text-[#5C2C16] leading-snug">${movie.title}</h3>
                        </div>
                        <button onclick="deleteMovie(${movie.id})" class="text-gray-300 hover:text-rose-500 transition p-1 no-print">
                            <i data-lucide="trash-2" class="w-3.5 h-3.5"></i>
                        </button>
                    </div>
                    <div class="text-[10px] font-bold text-amber-500 flex items-center gap-1">
