            let goingCount = 0;
            eventObj.guests.forEach(g => {
                if (g.rsvp === "Going") goingCount++;
                const rsvpColors = {
                    "Going": "bg-emerald-100 text-emerald-800",
                    "Pending": "bg-amber-100 text-amber-800",
                    "Tentative": "bg-sky-100 text-sky-800",
                    "No": "bg-rose-100 text-rose-800"
                };
                const div = document.createElement('div');
                div.className = "flex items-center justify-between p-1 bg-sky-50/40 rounded-lg text-xs border border-sky-100/50";
                div.innerHTML = `
                    <span class="font-medium text-[#5C2C16] truncate max-w-[60%]">${g.name}</span>
                    <div class="flex items-center gap-1 text-[10px]">
                        <button onclick="toggleEventGuestRsvp(${g.id})" class="px-1.5 py-0.5 rounded-md font-bold ${rsvpColors[g.rsvp]} transition-all">${g.rsvp}</button>
                        <button onclick="deleteEventGuest(${g.id})" class="text-gray-300 hover:text-rose-500 no-print">
                            <i data-lucide="x" class="w-3 h-3"></i>
                        </button>
                    </div>
                `;
                guestContainer.appendChild(div);
            });
            document.getElementById('guest-rsvp-count').innerText = `${goingCount} Going / ${eventObj.guests.length} Total`;

            const itinContainer = document.getElementById('event-itinerary-container');
            itinContainer.innerHTML = '';
            eventObj.itinerary.forEach(i => {
                const div = document.createElement('div');
                div.className = "flex items-start justify-between p-1.5 bg-rose-50/30 rounded-lg text-xs border border-rose-100/30";
                div.innerHTML = `
                    <div class="flex gap-2">
                        <span class="font-cute font-bold text-rose-500 bg-white px-1.5 rounded border border-rose-100 shrink-0">${i.time}</span>
                        <span class="text-[#5C2C16]">${i.task}</span>
                    </div>
                    <button onclick="deleteEventItinerary(${i.id})" class="text-gray-300 hover:text-rose-500 shrink-0 no-print">
